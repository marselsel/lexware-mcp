# ---- Lexware Office API ----
# Required. Create an API key at https://app.lexware.de/addons/public-api
# Treat it like banking credentials.
LEXWARE_API_KEY=

# Optional. API base URL (override for testing). Default: https://api.lexware.io
# LEXWARE_API_BASE_URL=https://api.lexware.io

# Optional. Web-app base used to build document deeplinks. Default: https://app.lexware.de
# LEXWARE_APP_BASE_URL=https://app.lexware.de

# ---- MCP endpoint protection ----
# Required (unless MCP_ALLOW_UNAUTHENTICATED=true). Static bearer token that
# clients must send to reach /mcp. Generate a strong one:
#   openssl rand -hex 32
MCP_AUTH_TOKEN=

# Escape hatch: run WITHOUT auth on /mcp. Only for trusted local testing —
# never expose an unauthenticated server to the internet.
# MCP_ALLOW_UNAUTHENTICATED=false

# ---- OAuth (optional; required for the Claude app's "custom connector" UI) ----
# Set OAUTH_ISSUER to switch /mcp to OAuth 2.1 (takes precedence over MCP_AUTH_TOKEN).
# The server then advertises this authorization server and validates the JWT access
# tokens it issues. Example: a WorkOS AuthKit domain.
# OAUTH_ISSUER=https://your-tenant.authkit.app
#
# This server's public URL — used as the token audience / Resource Indicator.
# Required in OAuth mode (SERVER_URL is accepted as an alias).
# OAUTH_RESOURCE=https://your-server.example.com
# SERVER_URL=https://your-server.example.com
#
# Restrict access to these email domains (comma-separated). Enforced server-side in addition to
# your provider's rules. STRONGLY recommended: if left empty in OAuth mode, ANY user who can
# authenticate with your issuer can reach the server.
# OAUTH_ALLOWED_EMAIL_DOMAINS=example.com
#
# Verify the access token's audience (aud) equals OAUTH_RESOURCE. Default: true — keep it.
# Setting it false makes the server accept ANY valid token from the issuer, including one
# minted for a different app on the same issuer (a confused-deputy risk). Only disable for a
# dedicated, single-audience issuer that has no Resource Indicator configured.
# OAUTH_VERIFY_AUDIENCE=true
#
# Overrides (defaults derived from OAUTH_ISSUER):
# OAUTH_JWKS_URL=https://your-tenant.authkit.app/oauth2/jwks
# OAUTH_USERINFO_URL=https://your-tenant.authkit.app/oauth2/userinfo

# ---- Capabilities (choose your risk level) ----
# Master switch: when true, ONLY read tools are registered (overrides the flags below).
# LEXWARE_READ_ONLY=false

# Create-draft tools (draft invoices/quotations, create contacts). Default: true
# LEXWARE_ENABLE_DRAFTS=true

# Finalize / legally-binding write tools (issue invoices). IRREVERSIBLE. Default: false
# LEXWARE_ENABLE_FINALIZE=false

# ---- Server ----
# Listen port. Cloud Run injects this automatically. Default: 8080
# PORT=8080

# Verbose logging (method/path/status only — never secrets or bodies). Default: false
# LEXWARE_DEBUG_LOGGING=false
